{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redshed.ai/schemas/factory/job_spec_schema.json",
  "title": "Factory Job Spec Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "title",
    "state",
    "version",
    "type",
    "priority",
    "kernel",
    "factory_mode",
    "optimization_scope",
    "hardware_target",
    "reference_label",
    "description",
    "objective_vector",
    "scope",
    "contracts",
    "acceptance_gates",
    "benchmark_set",
    "profiling_requirements",
    "dependency_policy",
    "failure_budget",
    "stop_condition",
    "primary_files",
    "done_criteria"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "job_id": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["not_started", "in_progress", "blocked", "complete", "discarded"]
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["algorithm", "kernel", "research", "infra", "test", "integration"]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "kernel": {
      "type": "string",
      "minLength": 1
    },
    "factory_mode": {
      "type": "string",
      "minLength": 1
    },
    "optimization_scope": {
      "type": "string",
      "enum": ["backend", "frontend", "hybrid", "measurement", "correctness"]
    },
    "hardware_target": {
      "type": "string",
      "minLength": 1
    },
    "reference_label": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_backend", "plugin_surface", "authoritative_behavior"],
      "properties": {
        "current_backend": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "plugin_surface": {
          "type": "string",
          "minLength": 1
        },
        "authoritative_behavior": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "objective_vector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correctness",
        "coverage",
        "weighted_performance",
        "dependency_reduction",
        "numerical_quality",
        "complexity"
      ],
      "properties": {
        "correctness": { "$ref": "#/$defs/objective_priority" },
        "coverage": { "$ref": "#/$defs/objective_priority" },
        "weighted_performance": { "$ref": "#/$defs/objective_priority" },
        "dependency_reduction": { "$ref": "#/$defs/objective_priority" },
        "numerical_quality": { "$ref": "#/$defs/objective_priority" },
        "complexity": { "$ref": "#/$defs/objective_priority" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": { "$ref": "#/$defs/non_empty_string_array" },
        "out_of_scope": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["numerical", "coverage", "performance", "memory", "reproducibility"],
      "properties": {
        "numerical": {
          "type": "object",
          "additionalProperties": false,
          "required": ["residual_metric", "residual_threshold", "output_shape", "diagonal_requirement", "non_spd_behavior"],
          "properties": {
            "residual_metric": { "type": "string", "minLength": 1 },
            "residual_threshold": { "type": "number", "exclusiveMinimum": 0 },
            "output_shape": { "type": "string", "minLength": 1 },
            "diagonal_requirement": { "type": "string", "minLength": 1 },
            "non_spd_behavior": { "type": "string", "minLength": 1 }
          }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required_classes", "explicit_padding_sizes", "durable_tests_required"],
          "properties": {
            "required_classes": { "$ref": "#/$defs/non_empty_string_array" },
            "explicit_padding_sizes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "integer", "minimum": 1 }
            },
            "durable_tests_required": { "type": "boolean" }
          }
        },
        "performance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary_metric", "gpu_resident_only", "exclude_host_transfer", "weighted_mix", "decision_basis"],
          "properties": {
            "primary_metric": { "type": "string", "minLength": 1 },
            "gpu_resident_only": { "type": "boolean" },
            "exclude_host_transfer": { "type": "boolean" },
            "weighted_mix": {
              "type": "object",
              "additionalProperties": false,
              "required": ["small_64_256", "medium_256_2048", "large_gt_2048"],
              "properties": {
                "small_64_256": { "type": "number", "minimum": 0, "maximum": 1 },
                "medium_256_2048": { "type": "number", "minimum": 0, "maximum": 1 },
                "large_gt_2048": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            },
            "decision_basis": { "type": "string", "minLength": 1 }
          },
          "allOf": [
            {
              "if": true,
              "then": {
                "properties": {
                  "weighted_mix": {
                    "properties": {
                      "small_64_256": true,
                      "medium_256_2048": true,
                      "large_gt_2048": true
                    }
                  }
                }
              }
            }
          ]
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_peak_memory_multiplier_vs_baseline",
            "new_persistent_buffers_require_justification",
            "temporary_allocations_should_be_reused_or_amortized"
          ],
          "properties": {
            "max_peak_memory_multiplier_vs_baseline": {
              "type": "number",
              "minimum": 1.0,
              "maximum": 2.0
            },
            "new_persistent_buffers_require_justification": { "type": "boolean" },
            "temporary_allocations_should_be_reused_or_amortized": { "type": "boolean" }
          }
        },
        "reproducibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "baseline_reproduction_required",
            "deterministic_fixed_input_runs_required",
            "benchmark_variance_max_fraction",
            "record_math_modes"
          ],
          "properties": {
            "baseline_reproduction_required": { "type": "boolean" },
            "deterministic_fixed_input_runs_required": { "type": "boolean" },
            "benchmark_variance_max_fraction": {
              "type": "number",
              "minimum": 0,
              "maximum": 0.25
            },
            "record_math_modes": { "type": "boolean" }
          }
        }
      }
    },
    "acceptance_gates": { "$ref": "#/$defs/non_empty_string_array" },
    "keep_rule": {
      "type": "string"
    },
    "benchmark_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_artifact", "required_scripts", "new_sweep_requirements", "artifact_output_dir"],
      "properties": {
        "baseline_artifact": { "type": "string", "minLength": 1 },
        "required_scripts": { "$ref": "#/$defs/non_empty_string_array" },
        "new_sweep_requirements": { "$ref": "#/$defs/non_empty_string_array" },
        "artifact_output_dir": { "type": "string", "minLength": 1 }
      }
    },
    "profiling_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_quantify", "escalate_if"],
      "properties": {
        "must_quantify": { "$ref": "#/$defs/non_empty_string_array" },
        "escalate_if": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "dependency_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retain_third_party_when_empirically_right", "replacement_allowed_only_if", "forbid_purity_rewrites"],
      "properties": {
        "retain_third_party_when_empirically_right": { "type": "boolean" },
        "replacement_allowed_only_if": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "correctness_and_coverage_pass",
            "numerical_stability_not_degraded",
            "plugin_end_to_end_data_justifies_change",
            "min_weighted_latency_improvement_fraction",
            "or_meaningful_dependency_reduction"
          ],
          "properties": {
            "correctness_and_coverage_pass": { "type": "boolean" },
            "numerical_stability_not_degraded": { "type": "boolean" },
            "plugin_end_to_end_data_justifies_change": { "type": "boolean" },
            "min_weighted_latency_improvement_fraction": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "or_meaningful_dependency_reduction": { "type": "boolean" }
          }
        },
        "forbid_purity_rewrites": { "type": "boolean" }
      }
    },
    "iteration_logging": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "fields"],
      "properties": {
        "required": { "type": "boolean" },
        "fields": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "failure_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discard_on_any_hard_gate_correctness_failure",
        "stop_after_repeated_non_improving_iterations",
        "escalate_if_baseline_not_reproducible",
        "escalate_if_no_actionable_bottleneck"
      ],
      "properties": {
        "discard_on_any_hard_gate_correctness_failure": { "type": "boolean" },
        "stop_after_repeated_non_improving_iterations": { "type": "boolean" },
        "escalate_if_baseline_not_reproducible": { "type": "boolean" },
        "escalate_if_no_actionable_bottleneck": { "type": "boolean" }
      }
    },
    "stop_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_improvement_fraction", "window_iterations", "alternate_condition"],
      "properties": {
        "min_improvement_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "window_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "alternate_condition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "primary_files": { "$ref": "#/$defs/non_empty_string_array" },
    "done_criteria": { "$ref": "#/$defs/non_empty_string_array" }
  },
  "$defs": {
    "objective_priority": {
      "type": "string",
      "enum": ["gate", "primary", "secondary"]
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
