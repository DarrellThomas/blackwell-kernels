{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redshed.ai/schemas/factory/watchdog_job_packet.json",
  "title": "Watchdog Job Packet Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_type",
    "generated_at",
    "assignment_status",
    "worker",
    "job",
    "context",
    "repo_local_spec",
    "protocol",
    "instructions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "packet_type": {
      "const": "watchdog_job_packet"
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
    },
    "assignment_status": {
      "type": "string",
      "enum": ["active", "idle"]
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "assigned_job_id",
        "shared_repo_root",
        "worktree_root",
        "branch",
        "packet_path"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "assigned_job_id": { "type": ["integer", "null"], "minimum": 1 },
        "shared_repo_root": { "type": ["string", "null"] },
        "worktree_root": { "type": "string", "minLength": 1 },
        "branch": { "type": ["string", "null"] },
        "packet_path": { "type": "string", "minLength": 1 }
      }
    },
    "job": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "title",
            "description",
            "state",
            "phase",
            "job_type",
            "kernel_type",
            "assigned_to",
            "execution_lane",
            "priority",
            "version",
            "factory_mode",
            "optimization_scope",
            "hardware_target",
            "reference_label",
            "shared_project_dir",
            "worktree_project_dir",
            "source_file",
            "shared_source_path",
            "worktree_source_path",
            "db_spec_markdown",
            "acceptance_gates_text",
            "shipping"
          ],
          "properties": {
            "id": { "type": "integer", "minimum": 1 },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "state": { "type": "string" },
            "phase": { "type": "string" },
            "job_type": { "type": "string" },
            "kernel_type": { "type": "string" },
            "assigned_to": { "type": "string" },
            "execution_lane": { "type": "string" },
            "priority": { "type": ["integer", "null"] },
            "version": { "type": "string" },
            "factory_mode": { "type": "string" },
            "optimization_scope": { "type": "string" },
            "hardware_target": { "type": "string" },
            "reference_label": { "type": "string" },
            "shared_project_dir": { "type": ["string", "null"] },
            "worktree_project_dir": { "type": ["string", "null"] },
            "source_file": { "type": "string" },
            "shared_source_path": { "type": ["string", "null"] },
            "worktree_source_path": { "type": ["string", "null"] },
            "db_spec_markdown": { "type": "string" },
            "acceptance_gates_text": { "type": "string" },
            "shipping": {
              "type": "object",
              "additionalProperties": false,
              "required": ["ok", "mode", "detail", "error", "project_dir"],
              "properties": {
                "ok": { "type": "boolean" },
                "mode": { "type": "string" },
                "detail": { "type": "string" },
                "error": { "type": "string" },
                "project_dir": { "type": ["string", "null"] }
              }
            }
          }
        }
      ]
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_messages",
        "recent_messages",
        "experiment_summary",
        "local_file_hints"
      ],
      "properties": {
        "open_messages": {
          "type": "array",
          "items": { "$ref": "#/$defs/message_row" }
        },
        "recent_messages": {
          "type": "array",
          "items": { "$ref": "#/$defs/message_row" }
        },
        "experiment_summary": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "local_file_hints": {
          "type": "array",
          "items": { "$ref": "#/$defs/file_hint" }
        }
      }
    },
    "repo_local_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "present",
        "job_json_path",
        "schema_path",
        "validator_path",
        "validation_status",
        "validation_errors",
        "document"
      ],
      "properties": {
        "present": { "type": "boolean" },
        "job_json_path": { "type": ["string", "null"] },
        "schema_path": { "type": ["string", "null"] },
        "validator_path": { "type": ["string", "null"] },
        "validation_status": {
          "type": "string",
          "enum": [
            "not_present",
            "valid",
            "invalid",
            "missing_schema",
            "invalid_json",
            "invalid_schema",
            "validator_unavailable"
          ]
        },
        "validation_errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "document": {
          "type": ["object", "null"],
          "additionalProperties": true
        }
      }
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "heartbeat_working",
        "refresh_commands",
        "done",
        "check_my_work",
        "problem",
        "research_session",
        "research_guidance"
      ],
      "properties": {
        "heartbeat_working": { "type": ["string", "null"] },
        "refresh_commands": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "job_show",
            "messages",
            "experiment_summary",
            "validate_repo_local_spec"
          ],
          "properties": {
            "job_show": { "type": ["string", "null"] },
            "messages": { "type": ["string", "null"] },
            "experiment_summary": { "type": ["string", "null"] },
            "validate_repo_local_spec": { "type": ["string", "null"] }
          }
        },
        "done": { "$ref": "#/$defs/handoff_commands" },
        "check_my_work": { "$ref": "#/$defs/handoff_commands" },
        "problem": {
          "allOf": [
            { "$ref": "#/$defs/handoff_commands" },
            {
              "type": "object",
              "required": ["guidance"],
              "properties": {
                "guidance": { "type": "string" }
              }
            }
          ]
        },
        "research_session": { "type": "string" },
        "research_guidance": { "type": "string" }
      }
    },
    "instructions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "constraints",
        "refresh_order",
        "handoff_signals"
      ],
      "properties": {
        "summary": { "type": "string" },
        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "refresh_order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "handoff_signals": {
          "type": "array",
          "items": { "type": "string", "enum": ["done", "check my work", "problem"] }
        }
      }
    }
  },
  "$defs": {
    "message_row": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "file_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared_path",
        "relative_path",
        "kind",
        "shared_path",
        "worktree_path",
        "exists_in_shared_repo",
        "exists_in_worktree",
        "sources"
      ],
      "properties": {
        "declared_path": { "type": "string", "minLength": 1 },
        "relative_path": { "type": ["string", "null"] },
        "kind": { "type": "string", "enum": ["file", "pattern"] },
        "shared_path": { "type": ["string", "null"] },
        "worktree_path": { "type": ["string", "null"] },
        "exists_in_shared_repo": { "type": "boolean" },
        "exists_in_worktree": { "type": "boolean" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "handoff_commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heartbeat", "message"],
      "properties": {
        "heartbeat": { "type": ["string", "null"] },
        "message": { "type": ["string", "null"] },
        "guidance": { "type": "string" }
      }
    }
  }
}
