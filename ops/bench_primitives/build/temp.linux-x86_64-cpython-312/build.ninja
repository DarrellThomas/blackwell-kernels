ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -fno-strict-overflow -Wsign-compare -DNDEBUG -g -O2 -Wall -fPIC -I/data/src/bwk/common/csrc/common -I/home/darrell/.local/lib/python3.12/site-packages/torch/include -I/home/darrell/.local/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/usr/include/python3.12 -c
post_cflags = -O3 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=bench_primitives -std=c++17
cuda_cflags = -I/data/src/bwk/common/csrc/common -I/home/darrell/.local/lib/python3.12/site-packages/torch/include -I/home/darrell/.local/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/usr/include/python3.12 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 --use_fast_math --expt-relaxed-constexpr -lineinfo -arch=sm_120a -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=bench_primitives -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /data/src/bwk/ops/bench_primitives/build/temp.linux-x86_64-cpython-312/data/src/bwk/common/csrc/primitives/linalg/syrk_f32_sm120.o: cuda_compile /data/src/bwk/common/csrc/primitives/linalg/syrk_f32_sm120.cu
build /data/src/bwk/ops/bench_primitives/build/temp.linux-x86_64-cpython-312/data/src/bwk/common/csrc/primitives/linalg/trmm_f32_sm120.o: cuda_compile /data/src/bwk/common/csrc/primitives/linalg/trmm_f32_sm120.cu
build /data/src/bwk/ops/bench_primitives/build/temp.linux-x86_64-cpython-312/csrc/bindings.o: cuda_compile /data/src/bwk/ops/bench_primitives/csrc/bindings.cu








